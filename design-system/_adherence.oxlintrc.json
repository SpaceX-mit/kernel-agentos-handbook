{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/editorial/**",
              "components/motion/**",
              "components/ornaments/**",
              "components/spreads/**",
              "components/structure/**",
              "ui_kits/archive/**",
              "ui_kits/inner-page/**",
              "ui_kits/magazine/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:EB Garamond|Courier Prime))/i]",
        "message": "Font not provided by the design system. Available: EB Garamond, Courier Prime."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: children, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tomato|ink|kraft)$/]",
        "message": "<Banner> variant must be one of 'tomato' | 'ink' | 'kraft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CatalogRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|en|jp|tag|tagVariant|key|ref|className|style|children)$/]",
        "message": "<CatalogRow> doesn't accept that prop. Declared props: n, en, jp, tag, tagVariant."
      },
      {
        "selector": "JSXOpeningElement[name.name='CatalogRow'] > JSXAttribute[name.name='tagVariant'] > Literal[value!=/^(?:tomato|ink|kraft)$/]",
        "message": "<CatalogRow> tagVariant must be one of 'tomato' | 'ink' | 'kraft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColophonIssue'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|key|ref|className|style|children)$/]",
        "message": "<ColophonIssue> doesn't accept that prop. Declared props: number, month, year."
      },
      {
        "selector": "JSXOpeningElement[name.name='IssueMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|key|ref|className|style|children)$/]",
        "message": "<IssueMeta> doesn't accept that prop. Declared props: number, month, year."
      },
      {
        "selector": "JSXOpeningElement[name.name='IssueMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|key|ref|className|style|children)$/]",
        "message": "<IssueMeta> doesn't accept that prop. Declared props: number, month, year."
      },
      {
        "selector": "JSXOpeningElement[name.name='IssueMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|key|ref|className|style|children)$/]",
        "message": "<IssueMeta> doesn't accept that prop. Declared props: number, month, year."
      },
      {
        "selector": "JSXOpeningElement[name.name='InterviewSubject'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|nameJp|role|roleJp|location|key|ref|className|style|children)$/]",
        "message": "<InterviewSubject> doesn't accept that prop. Declared props: name, nameJp, role, roleJp, location."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoverIssue'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|price|key|ref|className|style|children)$/]",
        "message": "<CoverIssue> doesn't accept that prop. Declared props: number, month, year, price."
      },
      {
        "selector": "JSXOpeningElement[name.name='KernelLoading'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|key|ref|className|style|children)$/]",
        "message": "<KernelLoading> doesn't accept that prop. Declared props: size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|jp|tomato|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, jp, tomato."
      },
      {
        "selector": "JSXOpeningElement[name.name='FrameIssue'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|tagline|key|ref|className|style|children)$/]",
        "message": "<FrameIssue> doesn't accept that prop. Declared props: number, month, year, tagline."
      },
      {
        "selector": "JSXOpeningElement[name.name='Monument'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|price|key|ref|className|style|children)$/]",
        "message": "<Monument> doesn't accept that prop. Declared props: number, month, year, price."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<PopIcon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopIcon'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PopIcon> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopPathText'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|preset|d|fontSize|color|size|key|ref|className|style|children)$/]",
        "message": "<PopPathText> doesn't accept that prop. Declared props: text, preset, d, fontSize, color, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopPathText'] > JSXAttribute[name.name='preset'] > Literal[value!=/^(?:arc-top|arc-bottom|wave)$/]",
        "message": "<PopPathText> preset must be one of 'arc-top' | 'arc-bottom' | 'wave'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopPathText'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:tomato|ink|coffee|ivory|current)$/]",
        "message": "<PopPathText> color must be one of 'tomato' | 'ink' | 'coffee' | 'ivory' | 'current'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopPathText'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PopPathText> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopShape'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|label|key|ref|className|style|children)$/]",
        "message": "<PopShape> doesn't accept that prop. Declared props: name, size, color, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopShape'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PopShape> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PopShape'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:tomato|ink|coffee|ivory|current)$/]",
        "message": "<PopShape> color must be one of 'tomato' | 'ink' | 'coffee' | 'ivory' | 'current'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IssueMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|month|year|key|ref|className|style|children)$/]",
        "message": "<IssueMeta> doesn't accept that prop. Declared props: number, month, year."
      },
      {
        "selector": "JSXOpeningElement[name.name='TerminalLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:prompt|agent|text|dim|key|ref|className|style|children)$/]",
        "message": "<TerminalLine> doesn't accept that prop. Declared props: prompt, agent, text, dim."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
